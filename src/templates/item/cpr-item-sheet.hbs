<div class="item-sheet">
  <div class="item-top-pane">

    <div class="item-image">
      <img src="{{item.img}}"
           class="item-image-block-img"
           data-action="editImage"
           data-field="img" />
        {{#if item.system.isUpgraded }}
          <i class="fa-solid fa-square-caret-up fa-xs" data-tooltip="{{localize "CPR.global.generic.upgraded"}}"></i>
        {{/if}}
        {{#if item.system.isInstalled }}
          <i class="fa-solid fa-circle-info fa-xs" data-tooltip="{{localize "CPR.global.generic.installed"}}"></i>
        {{/if}}
    </div>

    <div class="item-details">
      <div class="item-details-name text-large text-hero">
        {{localize (cprGetLocalizedlNameKey item)}}
      </div>

      <div class="item-details-info">
        {{#if (cprCompare item.system.brand "!==" "")}}
          <span class="text-pill">
            {{item.system.brand}}
          </span>
        {{/if}}
      </div>

      <div class="item-details-help">
        {{localize (cprFindConfigValue "objectTypes" item.type)}}
        <a class="help-article text-padding-left-smallest"
           href="{{cprWikiLink item.type}}"
           data-tooltip="{{localize "CPR.global.generic.helparticle"}}">
          <i class="fas fa-circle-question"></i>
        </a>
      </div>

      <div class="item-details-source">
        {{#if item.system.source.book}}
          {{item.system.source.book}}
          {{#unless (or (eq item.system.source.page "") (eq item.system.source.page null) (eq item.system.source.page undefined) (eq item.system.source.page 0))}}
            {{localize "CPR.global.generic.pageShort"}}
            {{item.system.source.page}}
          {{/unless}}
        {{/if}}
      </div>

      <div class="item-details-other">
        {{#if (cprIsDebug) }}
          ({{item.id}})
        {{/if}}
      </div>
    </div>
  </div>

  <div class="item-bottom-pane">
    <div class="item-bottom-tabs-section">
      <nav class="navtabs-item cpr-tabs nav text-semi tabs" data-group="primary">
        <div class="tab-pink-underlay">
          <a class="tab-label text-small tab-indent {{tabs.primary.item-description.cssClass}}"
             data-action="tab"
             data-group="primary"
             data-tab="item-description">
            {{localize "CPR.global.generic.description"}}
          </a>
        </div>
        <div class="tab-pink-underlay">
          <a class="tab-label text-small tab-indent {{tabs.primary.item-settings.cssClass}}"
             data-action="tab"
             data-group="primary"
             data-tab="item-settings">
            {{localize "CPR.settings.title"}}
          </a>
        </div>
        {{#if (cprHasTemplate item.type "effects") }}
          <div class="tab-pink-underlay">
            <a class="tab-label text-small tab-indent {{tabs.primary.item-effects.cssClass}}"
               data-action="tab"
               data-group="primary"
               data-tab="item-effects">
              {{localize "CPR.itemSheet.effects.effects"}}
            </a>
          </div>
        {{/if}}
      </nav>
    </div>
    <div class="item-bottom-content-section">
      <section class="tab item-description-grid {{tabs.primary.item-description.cssClass}}"
               data-group="primary"
               data-tab="item-description">
        {{> "systems/cyberpunk-red-core/templates/item/cpr-item-description.hbs" this}}
      </section>
      <section class="tab item-settings-grid {{tabs.primary.item-settings.cssClass}}"
               data-group="primary"
               data-tab="item-settings">
        {{> "systems/cyberpunk-red-core/templates/item/cpr-item-settings.hbs" this}}
      </section>
      {{#if (cprHasTemplate item.type "effects") }}
        <section class="tab item-effects-grid {{tabs.primary.item-effects.cssClass}}"
                 data-group="primary"
                 data-tab="item-effects">
          {{> "systems/cyberpunk-red-core/templates/item/cpr-item-effects.hbs" this}}
        </section>
      {{/if}}
    </div>
  </div>

</div>
